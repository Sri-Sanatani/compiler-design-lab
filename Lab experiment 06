#include <stdio.h>
#include <ctype.h>
#include <string.h>
#include <stdlib.h>

#define MAX_PROD  25
#define MAX_LEN   50
#define MAX_SET   200
#define MAX_TER   50
#define MAX_STACK 200

void followfirst(char, int, int);
void findfirst(char, int, int);
void follow(char c);

int count, n = 0;
char calc_first[MAX_PROD][MAX_SET];
char calc_follow[MAX_PROD][MAX_SET];
int m = 0;

char production[MAX_PROD][MAX_LEN];
char first[MAX_SET];
char f[MAX_SET];

int k;
char ck;
int e;

int main(void)
{
    int jm = 0, km = 0;
    int i;
    char c, ch;

    printf("How many productions? : ");
    scanf("%d", &count);

    if (count <= 0 || count > MAX_PROD) {
        printf("Invalid count.\n");
        return 0;
    }

    printf("\nEnter %d productions in form A=B where A and B are grammar symbols.\n", count);
    printf("Use # for epsilon.\n\n");

    for (i = 0; i < count; i++) {
        scanf("%49s", production[i]);   // safe read
    }

    // init calc_first with '!'
    for (k = 0; k < count; k++) {
        for (int kay = 0; kay < MAX_SET; kay++) {
            calc_first[k][kay] = '!';
        }
    }

    // ---------- FIRST ----------
    int kay;
    char done[MAX_PROD];
    int ptr = -1;

    int point1 = 0, point2, xxx;

    for (k = 0; k < count; k++) {
        c = production[k][0];
        point2 = 0;
        xxx = 0;

        for (kay = 0; kay <= ptr; kay++)
            if (c == done[kay]) xxx = 1;

        if (xxx == 1) continue;

        findfirst(c, 0, 0);
        ptr += 1;
        done[ptr] = c;

        printf("\nFirst(%c) = { ", c);
        calc_first[point1][point2++] = c;

        for (i = 0 + jm; i < n; i++) {
            int chk = 0;
            for (int lark = 0; lark < point2; lark++) {
                if (first[i] == calc_first[point1][lark]) {
                    chk = 1;
                    break;
                }
            }
            if (chk == 0) {
                printf("%c, ", first[i]);
                calc_first[point1][point2++] = first[i];
            }
        }
        printf("}\n");
        jm = n;
        point1++;
    }

    printf("\n-----------------------------------------------\n\n");

    // init calc_follow with '!'
    for (k = 0; k < count; k++) {
        for (int kay2 = 0; kay2 < MAX_SET; kay2++) {
            calc_follow[k][kay2] = '!';
        }
    }

    // ---------- FOLLOW ----------
    char donee[MAX_PROD];
    ptr = -1;
    point1 = 0;

    int land = 0;
    for (e = 0; e < count; e++) {
        ck = production[e][0];
        point2 = 0;
        xxx = 0;

        for (kay = 0; kay <= ptr; kay++)
            if (ck == donee[kay]) xxx = 1;

        if (xxx == 1) continue;

        land += 1;
        follow(ck);

        ptr += 1;
        donee[ptr] = ck;

        printf("Follow(%c) = { ", ck);
        calc_follow[point1][point2++] = ck;

        for (i = 0 + km; i < m; i++) {
            int chk = 0;
            for (int lark = 0; lark < point2; lark++) {
                if (f[i] == calc_follow[point1][lark]) {
                    chk = 1;
                    break;
                }
            }
            if (chk == 0) {
                printf("%c, ", f[i]);
                calc_follow[point1][point2++] = f[i];
            }
        }
        printf("}\n\n");
        km = m;
        point1++;
    }

    // ---------- TERMINALS ----------
    char ter[MAX_TER];
    for (k = 0; k < MAX_TER; k++) ter[k] = '!';

    int sid = 0;
    for (k = 0; k < count; k++) {
        int len = (int)strlen(production[k]);
        for (int pos = 0; pos < len; pos++) {
            char sym = production[k][pos];
            if (!isupper((unsigned char)sym) && sym != '#' && sym != '=' && sym != '\0') {
                int exists = 0;
                for (int ap = 0; ap < sid; ap++) {
                    if (ter[ap] == sym) { exists = 1; break; }
                }
                if (!exists && sid < MAX_TER - 2) {
                    ter[sid++] = sym;
                }
            }
        }
    }
    ter[sid++] = '$';

    printf("\n\t\tLL(1) Parsing Table\n");
    printf("\t============================================================\n");
    printf("\t\t|\t");
    for (int ap = 0; ap < sid; ap++) printf("%c\t", ter[ap]);
    printf("\n\t============================================================\n");

    // Unique nonterminals table rows
    char tableNT[MAX_PROD];
    int ntCount = 0;
    for (int ap = 0; ap < count; ap++) {
        char nt = production[ap][0];
        int exists = 0;
        for (int z = 0; z < ntCount; z++) if (tableNT[z] == nt) exists = 1;
        if (!exists) tableNT[ntCount++] = nt;
    }

    // Table cells store either:
    //  - '#' for epsilon production
    //  - a production index encoded as 'A'+index
    //  - '!' empty
    char table[MAX_PROD][MAX_TER + 1];
    for (int r = 0; r < ntCount; r++) {
        table[r][0] = tableNT[r];
        for (int c2 = 1; c2 <= sid; c2++) table[r][c2] = '!';
    }

    // Helper: get column index for terminal
    auto int termIndex(char t) {
        for (int z = 0; z < sid; z++) if (ter[z] == t) return z;
        return -1;
    }

    // Fill table using FIRST of RHS first symbol only (works for this production style)
    for (int ap = 0; ap < count; ap++) {
        char A = production[ap][0];
        char X = production[ap][2]; // first symbol on RHS (after '=')

        int row = -1;
        for (int r = 0; r < ntCount; r++) if (table[r][0] == A) { row = r; break; }
        if (row == -1) continue;

        if (X == '#') {
            // epsilon: put on FOLLOW(A)
            // find FOLLOW(A) row in calc_follow
            int idxFF = -1;
            for (int r = 0; r < count; r++) if (calc_follow[r][0] == A) { idxFF = r; break; }
            if (idxFF != -1) {
                for (int z = 1; z < MAX_SET && calc_follow[idxFF][z] != '!'; z++) {
                    int col = termIndex(calc_follow[idxFF][z]);
                    if (col != -1) table[row][col + 1] = '#';
                }
            }
        } else if (!isupper((unsigned char)X)) {
            // terminal
            int col = termIndex(X);
            if (col != -1) table[row][col + 1] = (char)('A' + ap);
        } else {
            // nonterminal: use its FIRST set
            int idxFirst = -1;
            for (int r = 0; r < count; r++) if (calc_first[r][0] == X) { idxFirst = r; break; }
            if (idxFirst != -1) {
                for (int z = 1; z < MAX_SET && calc_first[idxFirst][z] != '!'; z++) {
                    if (calc_first[idxFirst][z] == '#') continue;
                    int col = termIndex(calc_first[idxFirst][z]);
                    if (col != -1) table[row][col + 1] = (char)('A' + ap);
                }
            }
        }
    }

    // Print table
    for (int r = 0; r < ntCount; r++) {
        printf("\t  %c\t|\t", table[r][0]);
        for (int c2 = 1; c2 <= sid; c2++) {
            if (table[r][c2] == '!') {
                printf("\t");
            } else if (table[r][c2] == '#') {
                printf("%c=#\t", table[r][0]);
            } else {
                int idx = (int)table[r][c2] - 'A';
                if (idx >= 0 && idx < count) printf("%s\t", production[idx]);
                else printf("?\t");
            }
        }
        printf("\n");
    }

    // ---------- LL(1) PARSING ----------
    printf("\nEnter INPUT STRING (end with $): ");
    char input[100];
    scanf("%99s", input);

    printf("\nSTACK\t\tINPUT\t\tACTION\n");
    printf("-----------------------------------------------\n");

    char stack[MAX_STACK];
    int s_ptr = 0;
    int i_ptr = 0;

    stack[s_ptr++] = '$';
    stack[s_ptr++] = table[0][0]; // start symbol = first nonterminal row

    while (s_ptr > 0) {
        // print stack
        for (int z = 0; z < s_ptr; z++) putchar(stack[z]);
        printf("\t\t");

        // print input from i_ptr
        printf("%s\t\t", input + i_ptr);

        char top = stack[s_ptr - 1];
        char look = input[i_ptr];

        if (top == '$' && look == '$') {
            printf("ACCEPT\n");
            break;
        }

        if (!isupper((unsigned char)top)) {
            // terminal
            if (top == look) {
                s_ptr--;
                i_ptr++;
                printf("POP\n");
            } else {
                printf("REJECT (terminal mismatch)\n");
                break;
            }
        } else {
            // nonterminal
            int row = -1;
            for (int r = 0; r < ntCount; r++) if (table[r][0] == top) { row = r; break; }
            int col = termIndex(look);

            if (row == -1 || col == -1 || table[row][col + 1] == '!') {
                printf("REJECT (no rule)\n");
                break;
            }

            // pop nonterminal
            s_ptr--;

            if (table[row][col + 1] == '#') {
                printf("%c -> #\n", top);
                continue;
            } else {
                int idx = (int)table[row][col + 1] - 'A';
                printf("%s\n", production[idx]);

                // push RHS in reverse (skip "A=" part)
                int len = (int)strlen(production[idx]);
                for (int p = len - 1; p >= 2; p--) {
                    if (production[idx][p] != '#') {
                        stack[s_ptr++] = production[idx][p];
                    }
                }
            }
        }
    }

    return 0;
}

// ---------------- FOLLOW / FIRST FUNCTIONS ----------------

void follow(char c)
{
    if (production[0][0] == c) {
        f[m++] = '$';
    }

    for (int i = 0; i < count; i++) {
        int len = (int)strlen(production[i]);
        for (int j = 2; j < len; j++) {
            if (production[i][j] == c) {
                if (j + 1 < len) {
                    followfirst(production[i][j + 1], i, j + 2);
                }
                if (j + 1 >= len && c != production[i][0]) {
                    follow(production[i][0]);
                }
            }
        }
    }
}

void findfirst(char c, int q1, int q2)
{
    if (!isupper((unsigned char)c)) {
        first[n++] = c;
        return;
    }

    for (int j = 0; j < count; j++) {
        if (production[j][0] == c) {
            if (production[j][2] == '#') {
                if (production[q1][q2] == '\0')
                    first[n++] = '#';
                else if (production[q1][q2] != '\0' && (q1 != 0 || q2 != 0))
                    findfirst(production[q1][q2], q1, q2 + 1);
                else
                    first[n++] = '#';
            }
            else if (!isupper((unsigned char)production[j][2])) {
                first[n++] = production[j][2];
            }
            else {
                findfirst(production[j][2], j, 3);
            }
        }
    }
}

void followfirst(char c, int c1, int c2)
{
    if (!isupper((unsigned char)c)) {
        f[m++] = c;
        return;
    }

    int i = 0, j = 1;
    for (i = 0; i < count; i++) {
        if (calc_first[i][0] == c) break;
    }

    while (i < count && calc_first[i][j] != '!') {
        if (calc_first[i][j] != '#') {
            f[m++] = calc_first[i][j];
        } else {
            if (production[c1][c2] == '\0') {
                follow(production[c1][0]);
            } else {
                followfirst(production[c1][c2], c1, c2 + 1);
            }
        }
        j++;
    }
}