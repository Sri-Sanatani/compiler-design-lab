#include <stdio.h>
#include <string.h>

int dfa[100][2][100] = {0};   // NFA transitions: dfa[state][symbol][next] = 1
int go[10000][2] = {0};       // DFA transitions for subset-states (bitmask)
int state[10000] = {0};       // visited subset states
int arr[10000] = {0};         // queue of subset states
char str[1000];

int main() {
    int st, fin, in;
    int f[100];
    int i, j, k;

    printf("\n(Inputs must be 0 or 1)\n");

    printf("\nEnter the number of NFA states: ");
    scanf("%d", &st);

    if (st <= 0 || st >= 100) {
        printf("Invalid number of states.\n");
        return 0;
    }

    // Because arrays are limited to 10000, we need 2^st <= 9999
    if ((1 << st) >= 10000) {
        printf("Too many states for this program (need 2^st < 10000). Try st <= 13.\n");
        return 0;
    }

    printf("\nGive state numbers from 0 to %d\n", st - 1);

    printf("\nEnter number of final states: ");
    scanf("%d", &fin);

    printf("Enter final states: ");
    for (i = 0; i < fin; i++) {
        scanf("%d", &f[i]);
        if (f[i] < 0 || f[i] >= st) {
            printf("Invalid final state.\n");
            return 0;
        }
    }

    int rel;
    printf("\nEnter the number of transition rules in NFA: ");
    scanf("%d", &rel);

    printf("\nDefine each rule as: initial_state input_symbol(0/1) final_state\n");

    for (i = 0; i < rel; i++) {
        int p, q, r;
        scanf("%d %d %d", &p, &q, &r);

        if (p < 0 || p >= st || r < 0 || r >= st || (q != 0 && q != 1)) {
            printf("Invalid rule.\n");
            return 0;
        }
        dfa[p][q][r] = 1;
    }

    printf("\nEnter initial state: ");
    scanf("%d", &in);
    if (in < 0 || in >= st) {
        printf("Invalid initial state.\n");
        return 0;
    }

    // Convert initial state into bitmask subset
    int start = (1 << in);

    printf("\nSolving according to DFA (Subset Construction)\n\n");

    // BFS over subset-states
    int front = 0, back = 0;
    arr[back++] = start;
    state[start] = 1;

    while (front < back) {
        int subset = arr[front++];

        for (int sym = 0; sym < 2; sym++) {
            int newSubset = 0;

            // For each NFA state in 'subset', union its transitions on 'sym'
            for (k = 0; k < st; k++) {
                if (subset & (1 << k)) {
                    for (int nxt = 0; nxt < st; nxt++) {
                        if (dfa[k][sym][nxt]) {
                            newSubset |= (1 << nxt);
                        }
                    }
                }
            }

            go[subset][sym] = newSubset;

            if (!state[newSubset]) {
                state[newSubset] = 1;
                arr[back++] = newSubset;
            }
        }
    }

    // Print DFA table
    printf("DFA States (as subsets) and transitions:\n");
    printf("SubsetState\t on0\t on1\n");
    for (i = 0; i < back; i++) {
        int subset = arr[i];
        printf("%d\t\t %d\t %d\n", subset, go[subset][0], go[subset][1]);
    }

    // Test strings (3 times like your original code)
    for (int test = 0; test < 3; test++) {
        printf("\nEnter string (only 0/1): ");
        scanf("%s", str);

        int l = (int)strlen(str);
        int curr = start;

        printf("Path: %d-", curr);
        int invalid = 0;

        for (i = 0; i < l; i++) {
            if (str[i] != '0' && str[i] != '1') {
                invalid = 1;
                break;
            }
            curr = go[curr][str[i] - '0'];
            printf("%d-", curr);
        }

        if (invalid) {
            printf("\nInvalid string (only 0 and 1 allowed)\n");
            continue;
        }

        printf("\nFinal subset state: %d\n", curr);

        // Accept if curr subset contains any final state bit
        int accepted = 0;
        for (i = 0; i < fin; i++) {
            if (curr & (1 << f[i])) {
                accepted = 1;
                break;
            }
        }

        if (accepted) printf("String Accepted\n");
        else printf("String Rejected\n");
    }

    return 0;
}