#include <stdio.h>
#include <string.h>

int main() {
    char LHS[50], RHS[200];
    char parts[50][50];          // stores alternatives
    int partCount = 0;

    printf("Enter the production in form A->Aα|β|γ : ");
    scanf("%49[^-]->%199s", LHS, RHS);   // read LHS until '-' then read RHS

    // Split RHS by '|'
    char *tok = strtok(RHS, "|");
    while (tok != NULL) {
        strcpy(parts[partCount++], tok);
        tok = strtok(NULL, "|");
    }

    char alpha[50][50], beta[50][50];
    int aCount = 0, bCount = 0;

    // Separate alpha (left recursive) and beta (non-left-recursive)
    for (int i = 0; i < partCount; i++) {
        if (parts[i][0] == LHS[0]) {
            // Aα -> store α (remove the leading A)
            strcpy(alpha[aCount++], parts[i] + 1);
        } else {
            strcpy(beta[bCount++], parts[i]);
        }
    }

    if (aCount == 0) {
        printf("\nThe given grammar has NO immediate left recursion.\n");
        printf("%s->", LHS);
        for (int i = 0; i < partCount; i++) {
            printf("%s", parts[i]);
            if (i != partCount - 1) printf("|");
        }
        printf("\n");
        return 0;
    }

    // If left recursion exists, print new productions
    printf("\nProductions after eliminating left recursion:\n");

    // A -> βA' | ...
    printf("%s->", LHS);
    for (int i = 0; i < bCount; i++) {
        printf("%s%s'", beta[i], LHS);
        if (i != bCount - 1) printf("|");
    }
    printf("\n");

    // A' -> αA' | ... | ε
    printf("%s'->", LHS);
    for (int i = 0; i < aCount; i++) {
        printf("%s%s'", alpha[i], LHS);
        if (i != aCount - 1) printf("|");
    }
    printf("|ε\n");

    return 0;
}