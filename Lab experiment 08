#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

int isNonTerminal(char x) {
    return (x >= 'A' && x <= 'Z');
}

int isTerminal(char x) {
    // any symbol that is not uppercase letter and not '=' and not end
    return (!isNonTerminal(x) && x != '=' && x != '\0');
}

int isOperator(char x) {
    return (x == '+' || x == '-' || x == '*' || x == '/');
}

void notOperatorGrammar(void) {
    printf("Not operator grammar\n");
    exit(0);
}

int main() {
    char grm[20][50];
    int n;

    printf("Enter number of productions: ");
    scanf("%d", &n);

    printf("Enter productions like E=E+E (no spaces):\n");
    for (int i = 0; i < n; i++) {
        scanf("%49s", grm[i]);
    }

    int foundOp = 0;

    for (int i = 0; i < n; i++) {
        // Must have form A=...
        if (!isNonTerminal(grm[i][0]) || grm[i][1] != '=') {
            notOperatorGrammar();
        }

        // Scan RHS from index 2
        for (int j = 2; grm[i][j] != '\0'; j++) {
            char curr = grm[i][j];
            char next = grm[i][j + 1];

            // Operator grammar condition (basic):
            // No two non-terminals should be adjacent on RHS:  ...AB...  (invalid)
            if (isNonTerminal(curr) && isNonTerminal(next)) {
                notOperatorGrammar();
            }

            // Track if any operator is present
            if (isOperator(curr)) foundOp = 1;

            // Also, $ should NOT appear inside grammar
            if (curr == '$') {
                notOperatorGrammar();
            }
        }
    }

    if (foundOp)
        printf("Operator grammar\n");
    else
        printf("Not operator grammar (no operators found)\n");

    return 0;
}