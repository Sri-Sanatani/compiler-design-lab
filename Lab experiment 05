#include <stdio.h>
#include <ctype.h>
#include <string.h>

#define MAX_PROD 10
#define MAX_LEN  30
#define MAX_SET  100

void followfirst(char c, int prodIndex, int nextPos);
void follow(char c);
void findfirst(char c, int prodIndex, int nextPos);

int count = 0;                 // number of productions
int n = 0;                     // index for first[]
int m = 0;                     // index for f[]

char calc_first[MAX_PROD][MAX_SET];
char calc_follow[MAX_PROD][MAX_SET];

char production[MAX_PROD][MAX_LEN];

char f[MAX_SET], first[MAX_SET];

int main(void)
{
    int jm = 0, km = 0;
    int i, k, kay;
    char c, ck;

    // ---------------- Grammar ----------------
    count = 8;
    strcpy(production[0], "E=TR");
    strcpy(production[1], "R=+TR");
    strcpy(production[2], "R=#");
    strcpy(production[3], "T=FY");
    strcpy(production[4], "Y=*FY");
    strcpy(production[5], "Y=#");
    strcpy(production[6], "F=(E)");
    strcpy(production[7], "F=i");
    // -----------------------------------------

    // init calc_first with '!'
    for (k = 0; k < count; k++) {
        for (kay = 0; kay < MAX_SET; kay++) {
            calc_first[k][kay] = '!';
            calc_follow[k][kay] = '!';
        }
    }

    // ---------- FIRST ----------
    char done[MAX_PROD];
    int ptr = -1;
    int point1 = 0;

    for (k = 0; k < count; k++) {
        c = production[k][0];

        // check if already computed
        int already = 0;
        for (kay = 0; kay <= ptr; kay++) {
            if (c == done[kay]) { already = 1; break; }
        }
        if (already) continue;

        findfirst(c, 0, 0);
        done[++ptr] = c;

        printf("\nFirst(%c) = { ", c);
        int point2 = 0;
        calc_first[point1][point2++] = c;

        for (i = jm; i < n; i++) {
            int dup = 0;
            for (int l = 0; l < point2; l++) {
                if (first[i] == calc_first[point1][l]) { dup = 1; break; }
            }
            if (!dup) {
                printf("%c, ", first[i]);
                calc_first[point1][point2++] = first[i];
            }
        }
        printf("}\n");

        jm = n;
        point1++;
    }

    printf("\n-----------------------------------------------\n\n");

    // ---------- FOLLOW ----------
    char donee[MAX_PROD];
    ptr = -1;
    point1 = 0;

    for (int e = 0; e < count; e++) {
        ck = production[e][0];

        int already = 0;
        for (kay = 0; kay <= ptr; kay++) {
            if (ck == donee[kay]) { already = 1; break; }
        }
        if (already) continue;

        follow(ck);
        donee[++ptr] = ck;

        printf("Follow(%c) = { ", ck);
        int point2 = 0;
        calc_follow[point1][point2++] = ck;

        for (i = km; i < m; i++) {
            int dup = 0;
            for (int l = 0; l < point2; l++) {
                if (f[i] == calc_follow[point1][l]) { dup = 1; break; }
            }
            if (!dup) {
                printf("%c, ", f[i]);
                calc_follow[point1][point2++] = f[i];
            }
        }
        printf("}\n\n");

        km = m;
        point1++;
    }

    return 0;
}

void follow(char c)
{
    // If start symbol, add $
    if (production[0][0] == c) {
        f[m++] = '$';
    }

    for (int i = 0; i < count; i++) {
        int len = (int)strlen(production[i]);

        // RHS starts at index 2 (because format A=....)
        for (int j = 2; j < len; j++) {
            if (production[i][j] == c) {

                // If there is a symbol after c
                if (j + 1 < len) {
                    followfirst(production[i][j + 1], i, j + 2);
                }

                // If c is at end and not same as LHS
                if (j + 1 >= len && c != production[i][0]) {
                    follow(production[i][0]);
                }
            }
        }
    }
}

void findfirst(char c, int q1, int q2)
{
    if (!isupper((unsigned char)c)) {
        first[n++] = c;
        return;
    }

    for (int j = 0; j < count; j++) {
        if (production[j][0] == c) {

            char next = production[j][2]; // first symbol on RHS

            if (next == '#') { // epsilon
                // if we came from some production and there is something after
                if (q1 != 0 || q2 != 0) {
                    if (production[q1][q2] != '\0')
                        findfirst(production[q1][q2], q1, q2 + 1);
                    else
                        first[n++] = '#';
                } else {
                    first[n++] = '#';
                }
            }
            else if (!isupper((unsigned char)next)) {
                first[n++] = next;
            }
            else {
                findfirst(next, j, 3);
            }
        }
    }
}

void followfirst(char c, int prodIndex, int nextPos)
{
    if (!isupper((unsigned char)c)) {
        f[m++] = c;
        return;
    }

    // locate FIRST(c) in calc_first table
    int i;
    for (i = 0; i < count; i++) {
        if (calc_first[i][0] == c) break;
    }
    if (i == count) return; // not found (safety)

    int j = 1;
    while (calc_first[i][j] != '!') {

        if (calc_first[i][j] != '#') {
            f[m++] = calc_first[i][j];
        } else {
            // epsilon found: take FOLLOW if end, else continue with next symbol
            if (production[prodIndex][nextPos] == '\0') {
                follow(production[prodIndex][0]);
            } else {
                followfirst(production[prodIndex][nextPos], prodIndex, nextPos + 1);
            }
        }
        j++;
    }
}