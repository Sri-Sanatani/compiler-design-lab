#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main() {
    char m[50];
    char t[50][50];
    int n, i, j, r = 0, c = 0;

    printf("\n\t\t\t\tSIMULATION OF NFA");
    printf("\n\t\t\t\t*****************");

    // Initialize table with blanks
    for (i = 0; i < 50; i++) {
        for (j = 0; j < 50; j++) {
            t[i][j] = ' ';
        }
    }

    printf("\n\nEnter a regular expression: ");
    scanf("%49s", m);

    n = (int)strlen(m);

    for (i = 0; i < n; i++) {
        switch (m[i]) {

            case '|': {
                // Need valid i-1 and i+1
                if (i - 1 >= 0 && i + 1 < n) {
                    t[r][r + 1]   = 'E';
                    t[r + 1][r + 2] = m[i - 1];
                    t[r + 2][r + 5] = 'E';

                    t[r][r + 3]   = 'E';
                    t[r + 4][r + 5] = 'E';
                    t[r + 3][r + 4] = m[i + 1];

                    r = r + 5;
                }
                break;
            }

            case '*': {
                // Need valid i-1 and r-1
                if (i - 1 >= 0 && r - 1 >= 0) {
                    t[r - 1][r] = 'E';

                    t[r][r + 1] = 'E';
                    t[r][r + 3] = 'E';

                    t[r + 1][r + 2] = m[i - 1];
                    t[r + 2][r + 1] = 'E';
                    t[r + 2][r + 3] = 'E';

                    r = r + 3;
                }
                break;
            }

            case '+': {
                // Need valid i-1
                if (i - 1 >= 0) {
                    t[r][r + 1] = m[i - 1];
                    t[r + 1][r] = 'E';
                    r = r + 1;
                }
                break;
            }

            default: {
                // Handling concatenation of alphabets
                if (c == 0) {
                    if (isalpha((unsigned char)m[i]) && (i + 1 < n) && isalpha((unsigned char)m[i + 1])) {
                        t[r][r + 1] = m[i];
                        t[r + 1][r + 2] = m[i + 1];
                        r = r + 2;
                        c = 1;
                    } else {
                        c = 1;
                    }
                }
                else if (c == 1) {
                    if ((i + 1 < n) && isalpha((unsigned char)m[i + 1])) {
                        t[r][r + 1] = m[i + 1];
                        r = r + 1;
                        c = 2;
                    }
                }
                else {
                    if ((i + 1 < n) && isalpha((unsigned char)m[i + 1])) {
                        t[r][r + 1] = m[i + 1];
                        r = r + 1;
                        c = 3;
                    }
                }
                break;
            }
        }
    }

    // Print table header
    printf("\n\n");
    for (j = 0; j <= r; j++) printf(" %d", j);
    printf("\n-------------------------------------------------\n");

    // Print table
    for (i = 0; i <= r; i++) {
        for (j = 0; j <= r; j++) {
            printf(" %c", t[i][j]);
        }
        printf(" | %d", i);
        printf("\n");
    }

    printf("\nStart state: 0");
    printf("\nFinal state: %d\n", r);

    return 0;
}