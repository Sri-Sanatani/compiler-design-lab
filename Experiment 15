# Python program to implement Stack

MAX = 5
stack = []

def is_empty():
    return len(stack) == 0

def is_full():
    return len(stack) == MAX

def push():
    if is_full():
        print("Stack is full")
    else:
        item = input("Enter element to push: ")
        stack.append(item)
        print(item, "pushed into stack")

def pop():
    if is_empty():
        print("Stack is empty")
    else:
        item = stack.pop()
        print(item, "popped from stack")

def display():
    if is_empty():
        print("Stack is empty")
    else:
        print("Stack elements are:")
        for i in range(len(stack)-1, -1, -1):
            print(stack[i])

while True:
    print("\nSTACK OPERATIONS")
    print("1. Check if stack is empty")
    print("2. Push")
    print("3. Pop")
    print("4. Display")
    print("5. Exit")

    choice = int(input("Enter your choice: "))

    if choice == 1:
        if is_empty():
            print("Stack is empty")
        else:
            print("Stack is not empty")

    elif choice == 2:
        push()

    elif choice == 3:
        pop()

    elif choice == 4:
        display()

    elif choice == 5:
        print("Exiting program")
        break

    else:
        print("Invalid choice")